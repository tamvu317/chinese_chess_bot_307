#include <Arduino.h>
#include <math.h>

// ====== Tham so tay may ======
float L1 = 290.0;
float L2 = 180.0;

// ====== Goc ban dau cua 2 khop ======
float initialTheta1 = 0.0;    // Khop 1 ban dau o 0°
float initialTheta2 = 180.0;  // Khop 2 ban dau o 180°

// ====== Goc toa do ban dau ======
// Khi theta1=0°, theta2=180°:
// theta2_absolute = 0° + 180° = 180°
// x = 290*cos(0) + 180*cos(180) = 290 - 180 = 110
// y = 290*sin(0) + 180*sin(180) = 0
float initialX = 110.0;
float initialY = 0.0;

// ====== CNC Shield V3 ======
#define X_STEP_PIN 4
#define X_DIR_PIN 7
#define Y_STEP_PIN 2
#define Y_DIR_PIN 5

// ====== Step motor ======
const float stepsPerDegree_Theta1 = 11.11;
const float stepsPerDegree_Theta2 = 8.89;

float currentTheta1 = initialTheta1;
float currentTheta2 = initialTheta2;

// ====== Ham quay motor ======
void rotateMotor(int stepPin, int dirPin, float angle, float stepsPerDegree) {
  int steps = round(abs(angle) * stepsPerDegree);
  bool direction = (angle > 0) ? HIGH : LOW;
  
  digitalWrite(dirPin, direction);
  delay(10);
  
  for (int i = 0; i < steps; i++) {
    digitalWrite(stepPin, HIGH);
    delayMicroseconds(1000);
    digitalWrite(stepPin, LOW);
    delayMicroseconds(1000);
  }
  
  Serial.print("Quay: ");
  Serial.print(angle, 2);
  Serial.print("° (");
  Serial.print(steps);
  Serial.println(" steps)");
}

// ====== DONG HOC THUAN ======
void forwardKinematics(float theta1, float theta2, float &x, float &y) {
  float t1 = theta1 * PI / 180.0;
  float t2 = theta2 * PI / 180.0;
  
  float t2_absolute = t1 + t2;
  
  // Tính toạ độ so với khớp 1
  float x_rel = L1 * cos(t1) + L2 * cos(t2_absolute);
  float y_rel = L1 * sin(t1) + L2 * sin(t2_absolute);
  
  // Tọa độ tuyệt đối (không thêm initialX, initialY)
  x = x_rel;
  y = y_rel;
}

// ====== DONG HOC NGUOC ======
bool inverseKinematics(float x, float y, float &theta1, float &theta2) {
  // x, y là tọa độ từ khớp 1 trực tiếp
  float x_rel = x;
  float y_rel = y;
  
  float d = sqrt(x_rel*x_rel + y_rel*y_rel);
  
  if (d < abs(L1 - L2) || d > (L1 + L2)) {
    Serial.println("    Loi: Toa do nam ngoai vung!");
    Serial.print("    Khoang cach toi thieu: ");
    Serial.print(abs(L1 - L2), 2);
    Serial.print(" mm, Toi da: ");
    Serial.print((L1 + L2), 2);
    Serial.println(" mm");
    return false;
  }
  
  float cos_theta2 = (d*d - L1*L1 - L2*L2) / (2.0 * L1 * L2);
  
  if (cos_theta2 < -1.0 || cos_theta2 > 1.0) {
    Serial.println("    Loi: Khong the quay toi!");
    return false;
  }
  
  float sin_theta2 = sqrt(1.0 - cos_theta2 * cos_theta2);
  theta2 = atan2(sin_theta2, cos_theta2) * 180.0 / PI;
  
  float alpha = atan2(y_rel, x_rel) * 180.0 / PI;
  float t2_rad = theta2 * PI / 180.0;
  float beta = atan2(L2 * sin(t2_rad), L1 + L2 * cos(t2_rad)) * 180.0 / PI;
  theta1 = alpha - beta;
  
  while (theta1 > 180) theta1 -= 360;
  while (theta1 < -180) theta1 += 360;
  while (theta2 > 180) theta2 -= 360;
  while (theta2 < -180) theta2 += 360;
  
  return true;
}

void printStatus() {
  Serial.print("  Khau 1: ");
  Serial.print(currentTheta1, 2);
  Serial.print("°  |  Khau 2 (tuong doi): ");
  Serial.print(currentTheta2, 2);
  Serial.print("°  |  Khau 2 (tuyet doi): ");
  Serial.print(currentTheta1 + currentTheta2, 2);
  Serial.println("°");
}

void setup() {
  Serial.begin(9600);
  pinMode(X_STEP_PIN, OUTPUT);
  pinMode(X_DIR_PIN, OUTPUT);
  pinMode(Y_STEP_PIN, OUTPUT);
  pinMode(Y_DIR_PIN, OUTPUT);

  Serial.println("========== ROBOT ARM - KINEMATICS ==========");
  Serial.println("He dan dong:");
  Serial.println("  Khop 1: 20->80-22->110mm (ratio 1.25)");
  Serial.println("  Khop 2: 20->80-23->92mm  (ratio 1.0)");
  Serial.println("");
  Serial.print("Vi tri ban dau (home): theta1=");
  Serial.print(initialTheta1);
  Serial.print("°, theta2=");
  Serial.print(initialTheta2);
  Serial.print("° = (");
  Serial.print(initialX);
  Serial.print(", ");
  Serial.print(initialY);
  Serial.println(")");
  Serial.println("");
  Serial.println("CHE DO 1: Nhap goc -> Xuat toa do");
  Serial.println("  Lenh: angle theta1 theta2");
  Serial.println("  Vi du: angle 0 180");
  Serial.println("");
  Serial.println("CHE DO 2: Nhap toa do -> Xuat goc");
  Serial.println("  Lenh: coord x y");
  Serial.println("  Vi du: coord 110 0");
  Serial.println("");
  Serial.println("CHE DO 3: Ve vi tri ban dau");
  Serial.println("  Lenh: home");
  Serial.println("=========================================");
  
  Serial.println("\n>>> Trang thai hien tai:");
  printStatus();
}

void loop() {
  if (Serial.available()) {
    String cmd = Serial.readStringUntil('\n');
    cmd.trim();

    if (cmd == "home") {
      Serial.println("\n>>> Ve vi tri ban dau (home)...");
      
      float deltaTheta1 = initialTheta1 - currentTheta1;
      float deltaTheta2 = initialTheta2 - currentTheta2;
      
      if (deltaTheta1 != 0) {
        rotateMotor(X_STEP_PIN, X_DIR_PIN, deltaTheta1, stepsPerDegree_Theta1);
        delay(500);
      }
      if (deltaTheta2 != 0) {
        rotateMotor(Y_STEP_PIN, Y_DIR_PIN, deltaTheta2, stepsPerDegree_Theta2);
        delay(500);
      }
      
      currentTheta1 = initialTheta1;
      currentTheta2 = initialTheta2;
      
      Serial.println(">>> Trang thai hien tai:");
      printStatus();
      return;
    }

    int spacePos = cmd.indexOf(' ');
    if (spacePos == -1) {
      Serial.println("Loi: Nhap sai dinh dang!");
      Serial.println("Vui long nhap: angle theta1 theta2  hoac  coord x y");
      return;
    }

    String mode = cmd.substring(0, spacePos);
    String params = cmd.substring(spacePos + 1);

    if (mode == "angle") {
      int space2 = params.indexOf(' ');
      if (space2 == -1) {
        Serial.println("Loi: Nhap 'angle theta1 theta2'");
        return;
      }
      float theta1 = params.substring(0, space2).toFloat();
      float theta2 = params.substring(space2 + 1).toFloat();

      Serial.println("\n>>> CHE DO: ANGLE (Dong hoc thuan)");
      Serial.print(">>> Nhap: theta1=");
      Serial.print(theta1, 2);
      Serial.print("°, theta2=");
      Serial.print(theta2, 2);
      Serial.println("°");

      float deltaTheta1 = theta1 - currentTheta1;
      float deltaTheta2 = theta2 - currentTheta2;

      Serial.print(">>> Can quay: delta_theta1=");
      Serial.print(deltaTheta1, 2);
      Serial.print("°, delta_theta2=");
      Serial.print(deltaTheta2, 2);
      Serial.println("°");

      rotateMotor(X_STEP_PIN, X_DIR_PIN, deltaTheta1, stepsPerDegree_Theta1);
      delay(500);
      rotateMotor(Y_STEP_PIN, Y_DIR_PIN, deltaTheta2, stepsPerDegree_Theta2);
      delay(500);

      currentTheta1 = theta1;
      currentTheta2 = theta2;

      float x, y;
      forwardKinematics(theta1, theta2, x, y);

      Serial.println(">>> Trang thai hien tai:");
      printStatus();
      Serial.print(">>> Toa do: X=");
      Serial.print(x, 2);
      Serial.print(" mm, Y=");
      Serial.print(y, 2);
      Serial.println(" mm");
    }

    else if (mode == "coord") {
      int space2 = params.indexOf(' ');
      if (space2 == -1) {
        Serial.println("Loi: Nhap 'coord x y'");
        return;
      }
      float x = params.substring(0, space2).toFloat();
      float y = params.substring(space2 + 1).toFloat();

      Serial.println("\n>>> CHE DO: COORD (Dong hoc nguoc)");
      Serial.print(">>> Nhap toa do: X=");
      Serial.print(x, 2);
      Serial.print(" mm, Y=");
      Serial.print(y, 2);
      Serial.println(" mm");

      float theta1, theta2;
      if (!inverseKinematics(x, y, theta1, theta2)) {
        return;
      }

      Serial.print(">>> Can quay toi: theta1=");
      Serial.print(theta1, 2);
      Serial.print("°, theta2=");
      Serial.print(theta2, 2);
      Serial.println("°");

      float deltaTheta1 = theta1 - currentTheta1;
      float deltaTheta2 = theta2 - currentTheta2;

      Serial.print(">>> Can quay: delta_theta1=");
      Serial.print(deltaTheta1, 2);
      Serial.print("°, delta_theta2=");
      Serial.print(deltaTheta2, 2);
      Serial.println("°");

      rotateMotor(X_STEP_PIN, X_DIR_PIN, deltaTheta1, stepsPerDegree_Theta1);
      delay(500);
      rotateMotor(Y_STEP_PIN, Y_DIR_PIN, deltaTheta2, stepsPerDegree_Theta2);
      delay(500);

      currentTheta1 = theta1;
      currentTheta2 = theta2;

      Serial.println(">>> Trang thai hien tai:");
      printStatus();
    }

    else {
      Serial.println("Loi: Che do khong ton tai!");
      Serial.println("Vui long nhap: angle, coord, hoac home");
    }
  }
}
